fn isPrime(n: int): bool =
  var i = 2
  result = true
  while i * i <= n:
    if n == i * (n / i):
      result = false
      i = n
    i = i + 1

fn sieve(n: int): int =
  var i = 2
  var count = 0
  while i < n:
    if isPrime(i):
      count = count + 1
    i = i + 1
  result = count

echo sieve(5000)
